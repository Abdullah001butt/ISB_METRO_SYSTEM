// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AlertType {
  DELAY
  ROUTE_DEVIATION
  BREAKDOWN
  EMERGENCY
  OTHER
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum CrowdLevel {
  LOW
  MEDIUM
  HIGH
}

enum TripStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activityLogs ActivityLog[]
}

model Driver {
  id           String   @id @default(cuid())
  name         String
  cnic         String   @unique
  phone        String
  email        String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  buses    Bus[]
  trips    Trip[]
  messages DriverMessage[]
}

model Passenger {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  favoriteStations PassengerFavoriteStation[]
}

model PassengerFavoriteStation {
  id          String    @id @default(cuid())
  passengerId String
  passenger   Passenger @relation(fields: [passengerId], references: [id])
  stationId   String
  station     Station   @relation(fields: [stationId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([passengerId, stationId])
}

model PushSubscription {
  id             String    @id @default(cuid())
  endpoint       String    @unique
  p256dh         String
  auth           String
  stationId      String
  station        Station   @relation(fields: [stationId], references: [id])
  createdAt      DateTime  @default(now())
  lastNotifiedAt DateTime?

  @@index([stationId])
}

model DriverMessage {
  id        String    @id @default(cuid())
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id])
  message   String
  createdAt DateTime  @default(now())
  readAt    DateTime?
}

model Bus {
  id           String   @id @default(cuid())
  busNumber    String   @unique
  capacity     Int      @default(40)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  routeId String?
  route   Route?  @relation(fields: [routeId], references: [id])

  gpsLogs      GPSLog[]
  crowdStatus  CrowdStatus[]
  trips        Trip[]
  alerts       Alert[]
  aiPredictions AIPrediction[]
  stopRequests StopRequest[]
}

model Route {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buses      Bus[]
  busRoutes  BusRoute[]
  trips      Trip[]
}

model Station {
  id        String   @id @default(cuid())
  name      String   @unique
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  busRoutes         BusRoute[]
  pushSubscriptions PushSubscription[]
  favoritedBy       PassengerFavoriteStation[]
  stopRequests      StopRequest[]
}

model BusRoute {
  id        String @id @default(cuid())
  routeId   String
  route     Route  @relation(fields: [routeId], references: [id])
  stationId String
  station   Station @relation(fields: [stationId], references: [id])
  sequence  Int

  @@unique([routeId, stationId])
  @@unique([routeId, sequence])
}

model Trip {
  id        String     @id @default(cuid())
  busId     String
  bus       Bus        @relation(fields: [busId], references: [id])
  driverId  String
  driver    Driver     @relation(fields: [driverId], references: [id])
  routeId   String
  route     Route      @relation(fields: [routeId], references: [id])
  status    TripStatus @default(NOT_STARTED)
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime   @default(now())
}

enum StopRequestStatus {
  PENDING
  ACKNOWLEDGED
}

model StopRequest {
  id           String            @id @default(cuid())
  busId        String
  bus          Bus               @relation(fields: [busId], references: [id])
  stationId    String
  station      Station           @relation(fields: [stationId], references: [id])
  status       StopRequestStatus @default(PENDING)
  driverReply  String?
  createdAt    DateTime          @default(now())
  respondedAt  DateTime?

  @@index([busId, status])
}

model GPSLog {
  id        String   @id @default(cuid())
  busId     String
  bus       Bus      @relation(fields: [busId], references: [id])
  latitude  Float
  longitude Float
  speed     Float?
  recordedAt DateTime @default(now())

  @@index([busId, recordedAt])
}

model CrowdStatus {
  id        String     @id @default(cuid())
  busId     String
  bus       Bus        @relation(fields: [busId], references: [id])
  level     CrowdLevel
  recordedAt DateTime  @default(now())

  @@index([busId, recordedAt])
}

model Alert {
  id        String      @id @default(cuid())
  busId     String?
  bus       Bus?        @relation(fields: [busId], references: [id])
  type      AlertType
  status    AlertStatus @default(OPEN)
  message   String
  photoDataUrl String?
  createdAt DateTime    @default(now())
  resolvedAt DateTime?
}

model AIPrediction {
  id           String   @id @default(cuid())
  busId        String
  bus          Bus      @relation(fields: [busId], references: [id])
  stationId    String?
  predictedEtaMinutes Float?
  predictedDelayMinutes Float?
  createdAt    DateTime @default(now())

  @@index([busId, createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}
